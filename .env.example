# 数据库
DATABASE_URL=postgresql://postgres:password@localhost:5433/agentforge

# Redis
REDIS_URL=redis://localhost:6379

# LLM API
# OpenAI 协议用 /v2；Anthropic 协议用 /anthropic（与 LlmClient 自动匹配）
LLM_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
LLM_API_KEY=your-api-key
LLM_MODEL=astron-code-latest

# 飞书 OAuth 登录（管理台）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_REDIRECT_URI=http://localhost:5173/auth/feishu/callback
# 可选，空格分隔，需在飞书后台申请对应权限
# FEISHU_SCOPE=contact:user.base:readonly
# 事件订阅 Encrypt Key（机器人收消息回调验签，与 OAuth 不同）
# FEISHU_ENCRYPT_KEY=

# 公网根 URL（ngrok 域名或生产域名，无尾斜杠）
# PUBLIC_BASE_URL=https://xxxx.ngrok-free.app

# 飞书群 chat_id（oc_ 开头），在 Agent 详情页绑定
# 事件回调: {PUBLIC_BASE_URL}/webhook/feishu  或本地经 tunnel: ./scripts/tunnel.sh

# 服务配置
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Worker 配置
WORKER_COUNT=2
WORKER_CONCURRENCY=5