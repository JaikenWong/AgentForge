# 数据库
DATABASE_URL=postgresql://postgres:password@localhost:5433/agentforge

# Redis
REDIS_URL=redis://localhost:6379

# LLM API
LLM_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/anthropic
LLM_API_KEY=your-api-key
LLM_MODEL=astron-code-latest

# 飞书 OAuth 登录（管理台）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_REDIRECT_URI=http://localhost:5173/auth/feishu/callback
# 可选，空格分隔，需在飞书后台申请对应权限
# FEISHU_SCOPE=contact:user.base:readonly

# 服务配置
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Worker 配置
WORKER_COUNT=2
WORKER_CONCURRENCY=5